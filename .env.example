# Copier ce fichier en ".env" et renseigner la clé API Anthropic de CHV
# (créée sur https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Optionnel — valeurs par défaut déjà correctes pour démarrer
PORT=3000
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TASKS_PER_IMPORT=40

# Optionnel — dossier où stocker data.json. À utiliser en hébergement avec un disque
# persistant (ex. Render : /data). En local, laisse vide.
DATA_DIR=
