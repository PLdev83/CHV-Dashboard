# Copier ce fichier en ".env" et renseigner la clé API Anthropic de CHV
# (créée sur https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Optionnel — valeurs par défaut déjà correctes pour démarrer
PORT=3000
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TASKS_PER_IMPORT=40

# Requis — identifiants du projet Supabase (stockage des tâches).
# URL et clé service_role trouvables dans Supabase > Project Settings > API.
# La clé service_role a tous les droits : ne jamais l'exposer côté frontend.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optionnel — nom de la table Supabase (défaut : "tasks" si non définie).
# Permet de séparer données de test et de prod dans le même projet Supabase
# (même URL, même clé), en pointant vers une table différente. Ex. en local :
# SUPABASE_TABLE=tasks_dev
SUPABASE_TABLE=
